# ============================================================================
# ANTIGRAVITY MASTER HUSTLE ENGINE - ENVIRONMENT VARIABLES
# ============================================================================
# Copy this file to .env and fill in your actual credentials

# Server Configuration
PORT=3000

# Google Gemini API (required for content generation)
# Get your key from: https://aistudio.google.com/app/apikeys
GEMINI_API_KEY=your_google_gemini_api_key_here

# SMTP Configuration (Gmail recommended)
# For Gmail: Use App Password, not your regular password
# Generate at: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password_here

# HTTP Email Configuration (Alternative to SMTP to bypass port blocking on Render)
# If these two variables are defined, the backend sends emails via HTTPS POST requests to script.google.com
# GMAIL_HTTP_URL=https://script.google.com/macros/s/.../exec
# GMAIL_HTTP_KEY=your_secure_shared_key_here


# Admin Email (receives daily cron reports & error alerts)
ADMIN_EMAIL=your_email@gmail.com

# Marketing Link (shown at bottom of emails)
PS_LINK=https://jacksplugreviews.com
