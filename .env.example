PORT=3000
GEMINI_API_KEY=your_google_gemini_key

# SMTP Credentials (e.g. Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=jackbockholdt88@gmail.com
SMTP_PASS=YOUR_GMAIL_APP_PASSWORD

# Gmail HTTPS relay (Apps Script) — the send path that actually works on Render
# (Render blocks outbound SMTP; the SMTP_* vars above are a local-dev fallback only)
GMAIL_HTTP_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
GMAIL_HTTP_KEY=your_relay_shared_secret

# Shared daily outbound-email cap across ALL campaigns (pitches + follow-ups)
DAILY_SEND_CAP=50

# Admin Failure Notification
ADMIN_EMAIL=jackbockholdt88@gmail.com

# Marketing link at bottom of emails
PS_LINK=https://jacksplugreviews.com
